<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">{{ .SiteName }}</a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </nav>
    </header>

    <div class="layout-container">
        <!-- Main Feed -->
        <main>
            {{ if .Title }}
            <h1 class="page-title" style="margin-bottom: 24px;">{{ .Title }}</h1>
            {{ end }}

            {{ if .Articles }}
            <div class="grid-feed">
                {{ range .Articles }}
                <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                    <span class="grid-item-category">Article</span>
                    <h3>{{ .Title }}</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1.25rem; font-size: 0.95rem; line-height: 1.5;">{{ .Subtitle }}</p>
                    <div class="grid-item-date">
                        {{ .Date }} <span style="margin-left: auto;">Read More &rarr;</span>
                    </div>
                </a>
                {{ end }}
            </div>
            {{ end }}

            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="pagination-link arrow">&larr; Prev</a>
                {{ end }}

                <div class="pagination-numbers">
                    {{ range .Paginator.VisiblePages }}
                        {{ if .IsCurrent }}
                            <span class="page-number active">{{ .Number }}</span>
                        {{ else }}
                            <a href="{{ .URL }}" class="page-number">{{ .Number }}</a>
                        {{ end }}
                    {{ end }}
                </div>

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="pagination-link arrow">Next &rarr;</a>
                {{ end }}
            </div>
            {{ end }}
        </main>
    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
