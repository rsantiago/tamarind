<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                {{ if .Data.info.use_image_logo }}
                <img src="{{ .RelPrefix }}images/logo.png" alt="{{ .SiteName }}" style="height: 32px; width: auto; vertical-align: middle;">
                {{ else }}{{ .SiteName }}{{ end }}
            </a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </nav>
    </header>

    <div class="layout-container">
        <!-- Main Feed -->
        <main>
            {{ if .Title }}
            <h1 class="page-title" style="margin-bottom: 24px;">{{ .Title }}</h1>
            {{ end }}

            {{ if .Articles }}
            <div class="grid-feed">
                {{ range .Articles }}
                <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                    <span class="grid-item-category">Article</span>
                    <h3>{{ .Title }}</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1.25rem; font-size: 0.95rem; line-height: 1.5;">{{ .Subtitle }}</p>
                    <div class="grid-item-date">
                        {{ .Date }} <span style="margin-left: auto;">Read More &rarr;</span>
                    </div>
                </a>
                {{ end }}
            </div>
            {{ end }}

            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="pagination-link arrow">&larr; Prev</a>
                {{ end }}

                <div class="pagination-numbers">
                    {{ range .Paginator.VisiblePages }}
                        {{ if .IsCurrent }}
                            <span class="page-number active">{{ .Number }}</span>
                        {{ else }}
                            <a href="{{ .URL }}" class="page-number">{{ .Number }}</a>
                        {{ end }}
                    {{ end }}
                </div>

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="pagination-link arrow">Next &rarr;</a>
                {{ end }}
            </div>
            {{ end }}
        </main>
    </div>

    {{ template "footer.mdt" . }}


    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
