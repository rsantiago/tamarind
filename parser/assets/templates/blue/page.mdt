<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">{{ .SiteName }}</a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </nav>
    </header>

    <div class="layout-container">
        <!-- Main Content -->
        <main>
            <article class="card">
                <header class="post-header">
                     <h1>{{ .Title }}</h1>
                     {{ if .Subtitle }}<p class="page-subtitle">{{ .Subtitle }}</p>{{ end }}
                     
                    <div class="post-meta">
                        <div>
                             {{ .Date }} <span class="dot">&middot;</span> By {{ .Author }}
                        </div>
                    </div>
                </header>

                {{ if .Tags }}
                <div class="post-meta tags-container">
                     {{ range .Tags }}
                    <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="post-tag">#{{ . }}</a>
                     {{ end }}
                </div>
                {{ end }}

                <div class="post-content">
                    {{ .Body }}
                </div>
                
            </article>
        </main>
    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
