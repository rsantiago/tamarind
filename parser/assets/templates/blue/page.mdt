<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">{{ .SiteName }}</a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </nav>
    </header>

    <div class="layout-container">
        <!-- Main Content -->
        <main>
            <header class="article-header">
                 <h1 class="page-title">{{ .Title }}</h1>
                 {{ if .Subtitle }}<p class="page-subtitle">{{ .Subtitle }}</p>{{ end }}
                 
                <div class="post-meta" style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 16px;">
                     {{ .Date }} <span class="dot">&middot;</span> By {{ .Author }}
                </div>
            </header>

            <article class="article-content">
                {{ .Body }}

                {{ if .Tags }}
                <div class="tags-container" style="margin-top: 2rem;">
                     {{ range .Tags }}
                     <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="tag-link">#{{ . }}</a>
                     {{ end }}
                </div>
                {{ end }}
            </article>
        </main>
    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
