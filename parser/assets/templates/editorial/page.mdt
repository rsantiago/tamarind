<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
    <!-- Theme Specific: Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=block" rel="stylesheet">
    <!-- Theme Specific: Dark Mode Toggle Script -->
    <script>
        (function() {
            try {
                var localTheme = localStorage.getItem('site-theme');
                var support = window.matchMedia('(prefers-color-scheme: dark)');
                if (localTheme === 'dark' || (!localTheme && support.matches)) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            } catch (e) {}
        })();
    </script>
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                {{ if .Data.info.use_image_logo }}
                <img src="{{ .RelPrefix }}images/logo.png" alt="{{ .SiteName }}" style="height: 32px; width: auto; vertical-align: middle;">
                {{ else }}{{ .SiteName }}{{ end }}
            </a>
            <div class="header-actions">
                <ul class="nav-links">
                    {{ range .Menu }}
                    <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                    {{ end }}
                </ul>
                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
                    <span class="theme-toggle-icon sun">☀️</span>
                    <span class="theme-toggle-icon moon">🌙</span>
                </button>
            </div>
        </nav>
    </header>

    <main class="layout-container">
        <article class="post">
            <header class="post-header">
                {{ if .Date }}<p class="post-meta">{{ .Date }} by {{ .Author }}</p>{{ end }}
                <h1>{{ .Title }}</h1>
                {{ if .Subtitle }}<p class="post-subtitle">{{ .Subtitle }}</p>{{ end }}
            </header>

            <div class="post-content">
                {{ .Body }}
            </div>
            
            {{ if .Tags }}
            <footer class="post-footer">
                <div class="tags">
                    {{ range .Tags }}
                    <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html">#{{ . }}</a>
                    {{ end }}
                </div>
            </footer>
            {{ end }}
        </article>
    </main>

    {{ template "footer.mdt" . }}

    <script src="{{ .RelPrefix }}theme-toggle.js"></script>

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>


</html>
