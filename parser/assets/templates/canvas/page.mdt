<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <div class="layout-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <h3>Workspace</h3>
            <nav class="sidebar-nav">
                {{ range .Menu }}
                <a href="{{ $.RelPrefix }}{{ .URL }}"><span class="emoji">📄</span> {{ .Title }}</a>
                {{ end }}
            </nav>
        </aside>
        
        <div class="main-area">
            <!-- Breadcrumb Header -->
            <header class="site-header">
                <div class="nav-container">
                    <ul class="nav-links">
                        <li><a href="{{ .RelPrefix }}index.html">{{ .SiteName }}</a></li>
                        <span class="divider">/</span>
                        <li><a href="#">{{ if .Title }}{{ .Title }}{{ else }}Page{{ end }}</a></li>
                    </ul>
                </div>
            </header>

            <main>
                <article class="article-container">
                    <div class="article-header">
                        <div class="page-icon">📄</div>
                        <h1 class="page-title">{{ .Title }}</h1>
                        {{ if .Subtitle }}<p class="page-subtitle">{{ .Subtitle }}</p>{{ end }}
                    </div>
                    
                    <div class="article-content">
                        {{ .Body }}
                        
                        {{ if .Tags }}
                        <div class="tags-container">
                            {{ range .Tags }}
                            <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="tag-link">#{{ . }}</a>
                            {{ end }}
                        </div>
                        {{ end }}
                    </div>
                </article>
            </main>
        </div>
    </div>
    <div class="site-footer"></div>

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>
</html>
