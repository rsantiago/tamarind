<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <div class="layout-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <h3>Workspace</h3>
            <nav class="sidebar-nav">
                {{ range .Menu }}
                <a href="{{ $.RelPrefix }}{{ .URL }}"><span class="emoji">📄</span> {{ .Title }}</a>
                {{ end }}
            </nav>
        </aside>
        
        <div class="main-area">
            <!-- Breadcrumb Header -->
            <header class="site-header">
                <div class="nav-container">
                    <ul class="nav-links">
                        <li><a href="{{ .RelPrefix }}index.html">{{ .SiteName }}</a></li>
                        <span class="divider">/</span>
                        <li><a href="#">{{ if .Title }}{{ .Title }}{{ else }}Database{{ end }}</a></li>
                    </ul>
                </div>
            </header>

            <main>
                <div class="article-header">
                    <div class="page-icon">🗄️</div>
                    {{ if .Title }}
                    <h1 class="page-title">{{ .Title }}</h1>
                    {{ end }}
                </div>
                
                <div class="article-content">
                    {{ .Body }}
                </div>
                
                <!-- List Feed -->
                <div class="grid-feed">
                    {{ range .Articles }}
                    <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                        <span class="emoji" style="margin-right: 12px; font-size:18px;">📄</span>
                        <h3>{{ .Title }}</h3>
                        <div class="grid-item-date">{{ .Date }}</div>
                    </a>
                    {{ end }}
                </div>

                {{ if gt .Paginator.TotalPages 1 }}
                <div class="pagination" style="display:flex;gap:12px;margin-top:32px;align-items:center;">
                    {{ if .Paginator.HasPrev }}
                    <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary">&larr;</a>
                    {{ end }}

                    <div class="pagination-numbers" style="display:flex; gap:8px;">
                        {{ range .Paginator.VisiblePages }}
                            {{ if .IsCurrent }}
                                <span class="badge" style="background:var(--text-color);color:var(--background-color)">{{ .Number }}</span>
                            {{ else }}
                                <a href="{{ .URL }}" style="color:var(--text-secondary)">{{ .Number }}</a>
                            {{ end }}
                        {{ end }}
                    </div>

                    {{ if .Paginator.HasNext }}
                    <a href="{{ .Paginator.NextURL }}" class="btn btn-secondary">&rarr;</a>
                    {{ end }}
                </div>
                {{ end }}
            </main>
        </div>
    </div>
    <footer class="site-footer">
        <p class="footer-promo">
            This website was easily built with <a href="https://usetamarind.com" target="_blank" class="footer-link-tamarind">Tamarind</a>. 
            <a href="https://usetamarind.com" target="_blank" class="footer-link-cta">Start your own in 1 minute &rarr;</a>
        </p>
    </footer>

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>
</html>
