<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                <svg height="32" aria-hidden="true" viewBox="0 0 16 16" version="1.1" width="32" fill="currentColor"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"></path></svg>
                {{ .SiteName }}
            </a>
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        {{ if .Title }}
        <header class="article-header">
            <h1 class="page-title">{{ .Title }}</h1>
            <p class="page-subtitle">{{ .Subtitle }}</p>
        </header>
        {{ end }}

        <main>
            <div class="grid-feed">
                {{ range .Articles }}
                <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                    <h3>{{ .Title }}</h3>
                    <div class="grid-item-date">{{ .Date }}</div>
                </a>
                {{ end }}
            </div>

            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary">Previous</a>
                {{ else }}
                <span class="btn btn-secondary" style="opacity:0.5; pointer-events:none;">Previous</span>
                {{ end }}

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="btn btn-secondary">Next</a>
                {{ else }}
                <span class="btn btn-secondary" style="opacity:0.5; pointer-events:none;">Next</span>
                {{ end }}
            </div>
            {{ end }}
        </main>
    </div>

    {{ template "footer.mdt" . }}
</body>
</html>
