<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                {{ if .Data.info.use_image_logo }}
                <img src="{{ .RelPrefix }}images/logo.png" alt="{{ .SiteName }}" style="height: 32px; width: auto; vertical-align: middle;">
                {{ else }}
                <svg height="32" aria-hidden="true" viewBox="0 0 16 16" version="1.1" width="32" fill="currentColor"><path d="M5 3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm0 2.122a2.25 2.25 0 1 0-1.5 0v5.256a2.251 2.251 0 1 0 1.5 0V5.372zm8 0a2.25 2.25 0 1 0-1.5 0v.768c0 .502-.2 1.002-.555 1.358L8.66 9.782a.75.75 0 1 0 1.06 1.06l2.285-2.285c.641-.641.995-1.512.995-2.42V5.372zm-7.25 7.378a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm8-8a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"></path></svg>
                {{ .SiteName }}
            {{ end }}
            </a>
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        {{ if .Title }}
        <header class="article-header">
            <h1 class="page-title">{{ .Title }}</h1>
            <p class="page-subtitle">{{ .Subtitle }}</p>
        </header>
        {{ end }}

        <main>
            <div class="grid-feed">
                {{ range .Articles }}
                <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                    <h3>{{ .Title }}</h3>
                    <div class="grid-item-date">{{ .Date }}</div>
                </a>
                {{ end }}
            </div>

            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary">Previous</a>
                {{ else }}
                <span class="btn btn-secondary" style="opacity:0.5; pointer-events:none;">Previous</span>
                {{ end }}

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="btn btn-secondary">Next</a>
                {{ else }}
                <span class="btn btn-secondary" style="opacity:0.5; pointer-events:none;">Next</span>
                {{ end }}
            </div>
            {{ end }}
        </main>
    </div>

    {{ template "footer.mdt" . }}

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
