<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
    <!-- Theme Specific: Dark/Light Mode Bootstrapper -->
    <script>
        (function() {
            try {
                var localTheme = localStorage.getItem('site-theme');
                var support = window.matchMedia('(prefers-color-scheme: dark)');
                if (localTheme === 'dark' || (!localTheme && support.matches)) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                } else {
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            } catch (e) {}
        })();
    </script>
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <circle cx="12" cy="12" r="4"/>
                </svg>
                {{ .SiteName }}
            </a>
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
            <div class="header-actions" style="display:flex; align-items:center; gap:16px;">
                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
                    <span class="theme-toggle-icon sun">☀️</span>
                    <span class="theme-toggle-icon moon">🌙</span>
                </button>
            </div>
        </nav>
    </header>

    <main class="layout-container" id="feed">
        <section style="width: 100%;">
            <div class="article-header">
                <span class="badge">DESIGN & INNOVATION</span>
                <h1 class="page-title">Articles & Insights</h1>
                <p class="page-subtitle">A thoughtful collection of ideas, design philosophies, and architectural notes.</p>
            </div>

            <!-- Articles Grid Feed -->
            <div class="grid-feed">
                {{ range .Articles }}
                <div class="grid-item">
                    <div>
                        <div class="grid-item-category">JOURNAL</div>
                        <h3><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></h3>
                        {{ if .Subtitle }}
                        <p class="grid-item-desc">{{ .Subtitle }}</p>
                        {{ end }}
                    </div>
                    <div class="grid-item-date">{{ .Date }}</div>
                </div>
                {{ end }}
            </div>

            <!-- Pagination block -->
            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary btn-sm">&larr; Previous</a>
                {{ else }}
                <div></div>
                {{ end }}

                <div class="pagination-numbers" style="display:flex; gap:8px; align-items:center;">
                    {{ range .Paginator.VisiblePages }}
                        {{ if .IsCurrent }}
                            <span class="badge" style="background:var(--primary-color); color:#ffffff; border-color:var(--primary-color);">{{ .Number }}</span>
                        {{ else }}
                            <a href="{{ .URL }}" style="color:var(--text-secondary); font-weight: 600; padding: 4px 8px; font-size: 0.775rem;">{{ .Number }}</a>
                        {{ end }}
                    {{ end }}
                </div>

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="btn btn-secondary btn-sm">Next &rarr;</a>
                {{ else }}
                <div></div>
                {{ end }}
            </div>
            {{ end }}
        </section>
    </main>

    {{ template "footer.mdt" . }}

    <script src="{{ .RelPrefix }}theme-toggle.js"></script>
</body>

</html>
