<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
    <!-- Theme Specific: Dark/Light Mode Bootstrapper -->
    <script>
        (function() {
            try {
                var localTheme = localStorage.getItem('site-theme');
                var support = window.matchMedia('(prefers-color-scheme: dark)');
                if (localTheme === 'dark' || (!localTheme && support.matches)) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                } else {
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            } catch (e) {}
        })();
    </script>
</head>

<body>

    <header class="site-header">
        <nav class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                {{ if .Data.info.use_image_logo }}
                <img src="{{ .RelPrefix }}images/logo.png" alt="{{ .SiteName }}" style="height: 32px; width: auto; vertical-align: middle;">
                {{ else }}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <circle cx="12" cy="12" r="4"/>
                </svg>
                {{ .SiteName }}
                {{ end }}
            </a>
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
            <div class="header-actions" style="display:flex; align-items:center; gap:16px;">
                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
                    <span class="theme-toggle-icon sun">☀️</span>
                    <span class="theme-toggle-icon moon">🌙</span>
                </button>
            </div>
        </nav>
    </header>

    <div class="layout-container">
        {{ if .ContextualSidebar }}
        <aside class="sidebar">
        </aside>
        {{ end }}
        <main>
            <article class="article-container">
                <header class="article-header">
                    <h1 class="page-title">{{ .Title }}</h1>
                    {{ if .Subtitle }}
                    <p class="page-subtitle">{{ .Subtitle }}</p>
                    {{ end }}
                    {{ if .Date }}
                    <div style="font-size:0.775rem; color:var(--text-secondary); margin-top:16px; font-weight:500; font-family:var(--font-heading)">
                        PUBLISHED: {{ .Date }} {{ if .Author }}// BY: {{ .Author }}{{ end }}
                    </div>
                    {{ end }}
                </header>

                <div class="article-content">
                    {{ .Body }}
                    
                    {{ if .Tags }}
                    <div class="tags-container" style="margin-top:40px; display:flex; gap:8px; flex-wrap:wrap;">
                        {{ range .Tags }}
                        <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="badge">#{{ . }}</a>
                        {{ end }}
                    </div>
                    {{ end }}
                </div>
            </article>
        </main>
    </div>

    {{ template "footer.mdt" . }}

    <script src="{{ .RelPrefix }}theme-toggle.js"></script>
</body>

</html>
