<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                {{ if .Data.info.use_image_logo }}
                <img src="{{ .RelPrefix }}images/logo.png" alt="{{ .SiteName }}" style="height: 32px; width: auto; vertical-align: middle;">
                {{ else }}{{ .SiteName }}{{ end }}
            </a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        
        


        <!-- Grid Feed -->
        <main class="grid-feed">
            {{ range .Articles }}
            <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                <div class="grid-item-content">
                    <div class="grid-item-category">Article</div>
                    <h3>{{ .Title }}</h3>
                    <div class="grid-item-date">{{ .Date }}</div>
                </div>
            </a>
            {{ end }}
        </main>

        {{ if gt .Paginator.TotalPages 1 }}
        <div style="display: flex; justify-content: center; align-items: center; gap: 15px; margin: 40px 0; padding: 20px;">
            {{ if .Paginator.HasPrev }}
            <a href="{{ .Paginator.PrevURL }}" style="font-weight: 600;">&larr;</a>
            {{ end }}

            <div style="display: flex; gap: 8px;">
                {{ range .Paginator.VisiblePages }}
                    {{ if .IsCurrent }}
                        <span style="border-bottom: 2px solid var(--text-color); padding: 0 4px; font-weight: 700;">{{ .Number }}</span>
                    {{ else }}
                        <a href="{{ .URL }}" style="padding: 0 4px; color: var(--text-secondary);">{{ .Number }}</a>
                    {{ end }}
                {{ end }}
            </div>

            {{ if .Paginator.HasNext }}
            <a href="{{ .Paginator.NextURL }}" style="font-weight: 600;">&rarr;</a>
            {{ end }}
        </div>
        {{ end }}

    </div>

    {{ template "footer.mdt" . }}


    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
