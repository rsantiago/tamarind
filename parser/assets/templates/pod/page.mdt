<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-svg"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
                </div>
                TamarindPod
            </a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">

        <!-- Main Detail Page Content -->
        <main class="main-content">
            
            <article class="article-container">
                <!-- Large Podcast Episode Header Card -->
                <div class="podcast-header-card">
                    <div class="podcast-cover-large-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="podcast-cover-large-svg"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
                    </div>
                    <div class="podcast-meta-info">
                        <span class="podcast-type">Podcast Episode</span>
                        <h1 class="page-title">{{ .Title }}</h1>
                        <p class="page-subtitle">By {{ .Author }} • Published on {{ .Date }}</p>
                    </div>
                </div>

                <!-- Description / Episode Notes Content -->
                <div class="article-content">
                    <h2 style="font-size: 20px; font-weight: 800; margin-top: 0; margin-bottom: 16px;">Episode Notes</h2>
                    {{ .Body }}
                    
                    {{ if .Tags }}
                    <div class="tags-container">
                        {{ range .Tags }}
                        <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="tag-link">#{{ . }}</a>
                        {{ end }}
                    </div>
                    {{ end }}
                </div>
            </article>

        </main>
    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
