<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-svg"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
                </div>
                TamarindPod
            </a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">

        <!-- Main Content -->
        <main class="main-content">
            
            <!-- Playlist Banner -->
            <div class="podcast-header-card">
                <div class="podcast-cover-large-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="podcast-cover-large-svg"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v1a7 7 0 0 1-14 0v-1"></path><line x1="12" x2="12" y1="19" y2="22"></line></svg>
                </div>
                <div class="podcast-meta-info">
                    <span class="podcast-type">Public Playlist</span>
                    <h1 class="page-title">Weekly Dev Digest</h1>
                    <p class="page-subtitle">Your favorite articles formatted as custom podcasts and weekly insights. Handpicked by {{ .SiteName }}.</p>
                </div>
            </div>

            {{ if .Articles }}
                <table class="playlist-table">
                    <thead>
                        <tr>
                            <th class="playlist-index">#</th>
                            <th>Title</th>
                            <th>Release Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{ range $index, $element := .Articles }}
                        <tr class="playlist-row" onclick="window.location.href='{{ $.RelPrefix }}{{ .URL }}'">
                            <td class="playlist-index">
                                <span class="index-num">{{ add $index 1 }}</span>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="row-play-icon" width="14" height="14" style="display: none;"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                            </td>
                            <td>
                                <div class="playlist-title-cell">
                                    <div class="playlist-cover-mock">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="playlist-track-play-svg"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
                                    </div>
                                    <div class="playlist-title-text">
                                        <a href="{{ $.RelPrefix }}{{ .URL }}" class="playlist-track-link">
                                            <span class="playlist-track-name">{{ .Title }}</span>
                                        </a>
                                        <span class="playlist-track-author">{{ if .Author }}{{ .Author }}{{ else }}Tamarind Host{{ end }}</span>
                                    </div>
                                </div>
                            </td>
                            <td class="playlist-date">{{ .Date }}</td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
            {{ else }}
                <div style="text-align: center; padding: 80px 0;">
                    <h2>No tracks found in this playlist</h2>
                    <p style="color: var(--text-secondary); margin-top: 10px;">Check back later or compile new posts.</p>
                </div>
            {{ end }}

            <!-- Pagination -->
            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination-container" style="display: flex; justify-content: center; gap: 8px; margin-top: 40px;">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary btn-sm">&larr;</a>
                {{ end }}

                {{ range .Paginator.VisiblePages }}
                    {{ if .IsCurrent }}
                        <span class="btn btn-primary btn-sm" style="color: #000000;">{{ .Number }}</span>
                    {{ else }}
                        <a href="{{ .URL }}" class="btn btn-secondary btn-sm">{{ .Number }}</a>
                    {{ end }}
                {{ end }}

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="btn btn-secondary btn-sm">&rarr;</a>
                {{ end }}
            </div>
            {{ end }}

        </main>

    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
