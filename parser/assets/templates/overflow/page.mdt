<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                <span>tamarind</span>
            </a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">

        <!-- Main Question Details -->
        <main class="main-content">
            <article class="article-container">
                
                <div class="article-header">
                    <h1 class="page-title">{{ .Title }}</h1>
                    <div class="page-subtitle">
                        <span>Asked <strong>{{ .Date }}</strong></span>
                    </div>
                </div>

                <!-- Tamarind Overflow Post Layout Grid -->
                <div class="post-layout-grid">
                    
                    <!-- Right Main Content Panel -->
                    <div class="post-main-body">
                        <div class="article-content">
                            {{ .Body }}
                            
                            {{ if .Tags }}
                            <div class="tags-container">
                                {{ range .Tags }}
                                <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="tag-link">{{ . }}</a>
                                {{ end }}
                            </div>
                            {{ end }}
                        </div>

                        <!-- Author Card block -->
                        <div style="display: flex; justify-content: flex-end; margin-top: 32px;">
                            <div style="background-color: #e1ecf4; border-radius: var(--radius-sm); padding: 8px 12px; font-size: 12px; width: 200px;">
                                <div style="color: var(--text-secondary); margin-bottom: 6px;">asked {{ .Date }}</div>
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <div class="author-avatar" style="width: 32px; height: 32px; background-color: #0074cc; border-radius: var(--radius-sm);"></div>
                                    <div>
                                        <div style="color: #0074cc; font-weight: bold;">{{ if .Author }}{{ .Author }}{{ else }}Tamarind Author{{ end }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

            </article>
        </main>

    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
