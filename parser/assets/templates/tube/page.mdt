<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <div class="logo-container">
                <a href="{{ .RelPrefix }}index.html" class="logo">
                    <span>T</span> TamarindTube
                </a>
            </div>

            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        
        <main class="main-content">
            <article class="article-container">
                


                <div class="article-header">
                    <h1 class="page-title">{{ .Title }}</h1>
                    <div class="page-subtitle">{{ .Date }}</div>
                </div>

                <!-- Channel Info -->
                <div class="author-profile-bar">
                    <div class="profile-left">
                        <div class="author-avatar" style="width: 40px; height: 40px; font-size: 16px;">
                            {{ if .Author }}{{ printf "%.1s" .Author }}{{ else }}T{{ end }}
                        </div>
                        <div>
                            <div class="channel-name">By {{ if .Author }}{{ .Author }}{{ else }}Tamarind Creator{{ end }}</div>
                        </div>
                    </div>
                </div>

                <!-- Article Content -->
                <div class="article-content" style="margin-top: 24px;">
                    {{ .Body }}
                    
                    {{ if .Tags }}
                    <div class="tags-container">
                        {{ range .Tags }}
                        <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="tag-link">#{{ . }}</a>
                        {{ end }}
                    </div>
                    {{ end }}
                </div>

            </article>
        </main>
    </div>

    {{ template "footer.mdt" . }}


    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
