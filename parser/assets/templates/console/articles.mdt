<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">{{ .SiteName }}</a>
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        <main>
            <header class="article-header">
                {{ if .Title }}
                <h1 class="page-title">{{ .Title }}</h1>
                {{ end }}
            </header>
            
            <div class="article-content" style="margin-bottom:32px;">
                {{ .Body }}
            </div>
            
            <div class="grid-feed">
                {{ range .Articles }}
                <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                    <h3>{{ .Title }}</h3>
                    <div class="grid-item-date">[{{ .Date }}] {{ if .Tags }}(TAG: {{ index .Tags 0 }}){{ end }}</div>
                </a>
                {{ end }}
            </div>

            {{ if gt .Paginator.TotalPages 1 }}
            <div class="pagination">
                {{ if .Paginator.HasPrev }}
                <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary">< PREV_PAGE</a>
                {{ end }}

                <span class="badge">[ PG {{ .Paginator.CurrentPage }} / {{ .Paginator.TotalPages }} ]</span>

                {{ if .Paginator.HasNext }}
                <a href="{{ .Paginator.NextURL }}" class="btn btn-secondary">NEXT_PAGE ></a>
                {{ end }}
            </div>
            {{ end }}
        </main>
    </div>

    <footer class="site-footer">
        Connection closed. EOF.
    </footer>

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>
</html>
