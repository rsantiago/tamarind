<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">{{ .SiteName }}</a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        

        <!-- Grid Feed -->
        <main class="grid-feed">
            {{ range .Articles }}
            <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                <div class="grid-item-content">
                    <div class="grid-item-category">Article</div>
                    <h3>{{ .Title }}</h3>
                    <div class="grid-item-date">{{ .Date }}</div>
                </div>
            </a>
            {{ end }}
        </main>

        {{ if gt .Paginator.TotalPages 1 }}
        <div class="pagination">
            {{ if .Paginator.HasPrev }}
            <a href="{{ .Paginator.PrevURL }}" class="pagination-link arrow">&larr;</a>
            {{ end }}

            <div class="pagination-numbers">
                {{ range .Paginator.VisiblePages }}
                    {{ if .IsCurrent }}
                        <span class="page-number active">{{ .Number }}</span>
                    {{ else }}
                        <a href="{{ .URL }}" class="page-number">{{ .Number }}</a>
                    {{ end }}
                {{ end }}
            </div>

            {{ if .Paginator.HasNext }}
            <a href="{{ .Paginator.NextURL }}" class="pagination-link arrow">&rarr;</a>
            {{ end }}
        </div>
        {{ end }}

    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
