<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
</head>

<body>

    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">{{ .SiteName }}</a>
            
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        
        <main>
            <article class="article-container">


                <!-- "Image" Area (Title as the visual) -->
                <!-- Title Area -->
                <div class="article-header" style="justify-content: center; flex-direction: column; text-align: center;">
                     <h1 class="page-title">{{ .Title }}</h1>
                     {{ if .Subtitle }}<p style="color: var(--text-secondary); margin-top: 10px;">{{ .Subtitle }}</p>{{ end }}
                </div>
                
                <!-- Interaction Bar Removed -->

                <div class="article-content">
                    {{ .Body }}
                    
                    {{ if .Tags }}
                    <div style="margin-top: 2rem; font-size: 14px; color: var(--primary-color);">
                        {{ range .Tags }}
                        <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" style="margin-right: 8px; text-decoration: none;">#{{ . }}</a>
                        {{ end }}
                    </div>
                    {{ end }}

                    <div style="margin-top: 20px; font-size: 12px; color: #8e8e8e; text-transform: uppercase;">
                        {{ .Date }}
                    </div>
                </div>
            </article>
        </main>
    </div>

    {{ template "footer.mdt" . }}

</body>
</html>
