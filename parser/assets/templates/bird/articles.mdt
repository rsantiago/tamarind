<!DOCTYPE html>
<html lang="en">

<head>
    {{ template "head.mdt" . }}
    <!-- Theme Specific: Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" href="data:,">
</head>

<body>
    <div class="layout-container">
        <!-- Sidebar Navigation (Desktop) -->
        <header class="site-header">
            <div class="nav-container">
                <a href="{{ .RelPrefix }}index.html" class="logo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary-color);"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.58 1 9.2a7 7 0 0 1-13.9.8c-.1-.7.3-1.4 1-1.4H9a2 2 0 0 0 2-2v-.8c0-.7.7-1.1 1.4-1A9 9 0 0 1 11 20z"></path><path d="M19 2c-2.26 4.33-5.27 7.14-8 10"></path></svg>
                    <span>{{ .SiteName }}</span>
                </a>
                <nav class="nav-links">
                    <a href="{{ .RelPrefix }}index.html" class="nav-item">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        <span class="label">Home</span>
                    </a>

                    {{ range .Menu }}
                    {{ if ne .Title "Home" }}
                    <a href="{{ $.RelPrefix }}{{ .URL }}" class="nav-item">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        <span class="label">{{ .Title }}</span>
                    </a>
                    {{ end }}
                    {{ end }}
                </nav>
            </div>
        </header>

        <!-- Main Feed -->
        <main class="timeline">
            <!-- Sticky Header -->
            <div class="timeline-header">
                <div>
                   <h2 class="timeline-title">Feed</h2>
                 </div>
                 <div class="sparkles">✨</div>
            </div>

            <!-- Content -->
            <div class="feed-content">
                {{ if .Title }}
                <h1 class="page-title">{{ .Title }}</h1>
                {{ end }}
                {{ .Body }}
            </div>
            
            <!-- Articles List (if present) -->
             {{ if .Articles }}
            <div class="feed-posts">
                {{ range .Articles }}
                <a href="{{ $.RelPrefix }}{{ .URL }}" class="post">
                    <div class="post-avatar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line><line x1="17.5" y1="15" x2="9" y2="15"></line></svg>
                    </div>
                    <div class="post-content">
                        <!-- User requested removal of author and date - FILTERED OUT -->
                        <div class="post-body">
                            <span class="post-link">
                                {{ .Title }}
                            </span>
                            <p class="post-preview">{{ .Subtitle }}</p>
                        </div>
                    </div>
                </a>
                {{ end }}

                {{ if gt .Paginator.TotalPages 1 }}
                <div class="pagination">
                    {{ if .Paginator.HasPrev }}
                    <a href="{{ .Paginator.PrevURL }}" class="pagination-arrow">&larr;</a>
                    {{ end }}

                    <div class="pagination-numbers">
                        {{ range .Paginator.VisiblePages }}
                            {{ if .IsCurrent }}
                                <span class="page-number active">{{ .Number }}</span>
                            {{ else }}
                                <a href="{{ .URL }}" class="page-number link">{{ .Number }}</a>
                            {{ end }}
                        {{ end }}
                    </div>

                    {{ if .Paginator.HasNext }}
                    <a href="{{ .Paginator.NextURL }}" class="pagination-arrow">&rarr;</a>
                    {{ end }}
                </div>
                {{ end }}
            </div>
            {{ end }}
        </main>
        <!-- Right Sidebar (Trends) Removed entirely -->
    </div>
    {{ template "footer.mdt" . }}

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
