<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                {{ if .Data.info.use_image_logo }}
                <img src="{{ .RelPrefix }}images/logo.png" alt="{{ .SiteName }}" style="height: 32px; width: auto; vertical-align: middle;">
                {{ else }}{{ .SiteName }}{{ end }}
            </a>
            <ul class="nav-links">
                {{ range .Menu }}
                <li><a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a></li>
                {{ end }}
            </ul>
        </div>
    </header>

    <div class="layout-container">
        <div class="bento-card" style="padding-bottom: 24px;">
            <h1 class="page-title">{{ if .Title }}{{ .Title }}{{ else }}Latest Updates{{ end }}</h1>
            {{ if .Subtitle }}<p class="page-subtitle">{{ .Subtitle }}</p>{{ end }}
            
            <div class="article-content">
                {{ .Body }}
            </div>
        </div>
        
        <div class="grid-feed">
            {{ range .Articles }}
            <a href="{{ $.RelPrefix }}{{ .URL }}" class="grid-item">
                <h3>{{ .Title }}</h3>
                {{ if .Subtitle }}<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 16px; line-height:1.4;">{{ .Subtitle }}</p>{{ end }}
                <div class="grid-item-date">{{ .Date }}</div>
            </a>
            {{ end }}
        </div>

        {{ if gt .Paginator.TotalPages 1 }}
        <div class="pagination bento-card" style="padding: 24px;">
            {{ if .Paginator.HasPrev }}
            <a href="{{ .Paginator.PrevURL }}" class="btn btn-secondary">Previous</a>
            {{ end }}
            <span class="badge" style="align-self: center;">{{ .Paginator.CurrentPage }} / {{ .Paginator.TotalPages }}</span>
            {{ if .Paginator.HasNext }}
            <a href="{{ .Paginator.NextURL }}" class="btn btn-primary">Next</a>
            {{ end }}
        </div>
        {{ end }}
    </div>
    
    {{ template "footer.mdt" . }}

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
