<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "head.mdt" . }}
</head>
<body>
    <header class="site-header">
        <div class="nav-container">
            <a href="{{ .RelPrefix }}index.html" class="logo">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                {{ .SiteName }}
            </a>
        </div>
    </header>

    <div class="layout-container">
        <aside class="sidebar">
            <h3>Content</h3>
            <nav class="sidebar-nav">
                {{ range .Menu }}
                <a href="{{ $.RelPrefix }}{{ .URL }}">{{ .Title }}</a>
                {{ end }}
            </nav>
        </aside>
        
        <main>
            <article class="article-container">
                <div class="article-header">
                    <h1 class="page-title">{{ .Title }}</h1>
                    {{ if .Subtitle }}<p class="page-subtitle">{{ .Subtitle }}</p>{{ end }}
                </div>
                
                <div class="article-content">
                    {{ .Body }}
                    
                    {{ if .Tags }}
                    <div class="tags-container">
                        {{ range .Tags }}
                        <a href="{{ $.RelPrefix }}tags/{{ . | sanitizeTag }}.html" class="tag-link">#{{ . }}</a>
                        {{ end }}
                    </div>
                    {{ end }}
                </div>
            </article>
        </main>
    </div>

    {{ template "footer.mdt" . }}

    <!-- Ghost Badge -->
    <a href="https://usetamarind.com" target="_blank" class="tamarind-ghost-badge">
        Use Tamarind
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
</body>

</html>
