        <p style="font-size:0.75rem; opacity:0.75;">Powered by Tamarind Static Site Generator.</p>
        <p class="footer-rss-wrapper">
            <a href="{{ .RelPrefix }}feed.xml" class="footer-rss-link">RSS Feed</a>
        </p>
    </div>
</footer>

